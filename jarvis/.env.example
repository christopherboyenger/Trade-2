# ============================================================================
# Jarvis Dashboard configuration. Copy to .env and fill in what you need.
# Nothing here is required to BOOT — unconfigured venues show as "not connected"
# and the dashboard still runs. Add credentials to light each venue up.
# ============================================================================

# --- Server ---
PORT=8088

# --- Global trading mode -----------------------------------------------------
# paper = wire to paper/sandbox accounts only (default, safe).
# live  = allow real-money orders. Live orders ALSO require per-order confirm.
TRADING_MODE=paper

# --- The Jarvis brain (Claude) ----------------------------------------------
# Without this, the dashboard + portfolio still work; only the chat is disabled.
ANTHROPIC_API_KEY=
JARVIS_MODEL=claude-opus-4-8

# --- Stocks / ETFs via Alpaca ------------------------------------------------
# Paper keys: https://app.alpaca.markets/paper/dashboard/overview
# Live keys:  https://app.alpaca.markets/  (only used when TRADING_MODE=live)
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET_KEY=
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET_KEY=

# --- Crypto via Freqtrade REST API ------------------------------------------
# Run Freqtrade (in ../freqtrade) with api_server enabled, then point here.
# Freqtrade's own dry_run flag is its paper/live switch; Jarvis reads it.
FREQTRADE_URL=http://127.0.0.1:8080
FREQTRADE_USERNAME=
FREQTRADE_PASSWORD=

# --- Prediction markets via Polymarket (read-only in this MVP) ---------------
# Public market data needs no key. To see YOUR positions, set your wallet:
POLYMARKET_ADDRESS=
